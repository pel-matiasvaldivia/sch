# ================================================================
# HEMATOLOGÍA CLINIC — Variables de Entorno
# Copiá este archivo: cp .env.example .env
# Completá los valores marcados con CAMBIAR_*
# NUNCA commitear el archivo .env al repositorio
# ================================================================

# ─── APLICACIÓN ───
APP_ENV=development
APP_SECRET_KEY=CAMBIAR_POR_STRING_ALEATORIO_64_CHARS
APP_NAME="Sistema Hematología"
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── BASE DE DATOS ───
POSTGRES_USER=hema_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=hematologia_db
DATABASE_URL=postgresql+asyncpg://hema_user:CAMBIAR_POR_PASSWORD_SEGURO@postgres:5432/hematologia_db

# ─── REDIS ───
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
REDIS_URL=redis://:CAMBIAR_POR_PASSWORD_SEGURO@redis:6379/0

# ─── JWT ───
JWT_SECRET_KEY=CAMBIAR_POR_STRING_ALEATORIO_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── ELASTICSEARCH ───
ELASTICSEARCH_URL=http://elasticsearch:9200

# ─── MINIO (Storage) ───
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
MINIO_BUCKET_REPORTS=hema-reports
MINIO_BUCKET_DOCUMENTS=hema-documents
MINIO_BUCKET_AVATARS=hema-avatars
MINIO_ENDPOINT=minio:9000

# ─── EMAIL (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CAMBIAR_POR_EMAIL
SMTP_PASSWORD=CAMBIAR_POR_PASSWORD_SMTP
SMTP_FROM_NAME="Clínica Hematología"
SMTP_FROM_EMAIL=no-reply@clinica.com

# ─── WHATSAPP BUSINESS API ───
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=CAMBIAR_POR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=CAMBIAR_POR_TOKEN
WHATSAPP_VERIFY_TOKEN=CAMBIAR_WEBHOOK_VERIFY_TOKEN

# ─── SEGURIDAD ───
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_PER_MINUTE=60

# ─── FRONTEND ───
NEXT_PUBLIC_API_URL=http://localhost/api

# ─── OPCIONES DE MÓDULOS (feature flags) ───
FEATURE_WHATSAPP=false
FEATURE_2FA=true
FEATURE_ELASTICSEARCH=true
FEATURE_EMAIL_NOTIFICATIONS=true

# ─── CONFIGURACIÓN DE LA CLÍNICA ───
CLINIC_NAME="Clínica Hematológica"
CLINIC_ADDRESS=""
CLINIC_PHONE=""
CLINIC_LOGO_URL=""
CLINIC_CURRENCY=ARS
CLINIC_TIMEZONE=America/Argentina/Buenos_Aires
